---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL to the social-share image (1200×630). */
  image?: string;
  /** Open Graph type — "website" for landing pages, "article" for legal docs. */
  ogType?: string;
}

const {
  title = "Pacebeats — Run to the rhythm. Achieve your pace.",
  description = "Pacebeats syncs your music to your stride. An Android + Wear OS running companion that adapts your playlist to your pace in real time.",
  image = "/og-image.png",
  ogType = "website",
} = Astro.props;

// Astro.site is configured in astro.config.mjs. Fall back to the production
// origin so canonical/OG URLs are always absolute even in odd build contexts.
const SITE = Astro.site ?? new URL("https://www.pacebeats.top");
const canonicalURL = new URL(Astro.url.pathname, SITE).href;
const socialImageURL = new URL(image, SITE).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={description} />

    {/* Canonical — prevents duplicate-URL dilution (www, query strings, etc.) */}
    <link rel="canonical" href={canonicalURL} />

    {/* Crawler directives — index everything and allow large rich previews in
        Google, Discover, and AI answer engines. */}
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    {/* Open Graph — Facebook, LinkedIn, iMessage, Slack, and most AI engines */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Pacebeats" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pacebeats — run to the rhythm, achieve your pace." />
    <meta property="og:locale" content="en_US" />

    {/* Twitter / X large-image card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta name="twitter:image:alt" content="Pacebeats — run to the rhythm, achieve your pace." />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{title}</title>

    {/* Sitewide WebSite entity — clarifies the brand for search + AI knowledge
        graphs and declares the canonical name "Pacebeats". */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Pacebeats",
        alternateName: "Pacebeats Running App",
        url: "https://www.pacebeats.top",
        description:
          "Pacebeats is an Android + Wear OS running companion that adapts your music to your stride in real time.",
        inLanguage: "en",
        publisher: {
          "@type": "Organization",
          name: "Pacebeats",
          logo: {
            "@type": "ImageObject",
            url: "https://www.pacebeats.top/favicon.png",
          },
        },
      })}
    />
  </head>
  <body>
    <slot />

    <Analytics />

    <script is:inline>
      // Global reveal observer — toggles .is-visible on every reveal primitive
      // when it enters the viewport. Fires once per element. Re-runs on load
      // to catch elements rendered by hydrated React islands.
      (function () {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var SEL = '.reveal-words, .reveal-fade-rise, .reveal-line, .stagger';
        var seen = new WeakSet();
        var io = null;

        function reveal(el) { el.classList.add('is-visible'); }

        function ensureIO() {
          if (io || reduce || !('IntersectionObserver' in window)) return io;
          io = new IntersectionObserver(function (entries) {
            for (var i = 0; i < entries.length; i++) {
              if (entries[i].isIntersecting) {
                reveal(entries[i].target);
                io.unobserve(entries[i].target);
              }
            }
          }, { threshold: 0.1, rootMargin: '0px 0px -2% 0px' });
          return io;
        }

        function scan() {
          var targets = document.querySelectorAll(SEL);
          if (reduce || !('IntersectionObserver' in window)) {
            for (var i = 0; i < targets.length; i++) reveal(targets[i]);
            return;
          }
          ensureIO();
          for (var j = 0; j < targets.length; j++) {
            var el = targets[j];
            if (seen.has(el)) continue;
            seen.add(el);
            var rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight * 0.95 && rect.bottom > 0) {
              reveal(el);
            } else {
              io.observe(el);
            }
          }
        }

        function boot() {
          scan();
          // React islands may swap subtrees on hydration — rescan a few times.
          setTimeout(scan, 300);
          setTimeout(scan, 1200);
          setTimeout(scan, 2400);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', boot, { once: true });
        } else {
          boot();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  /* ===== Grain overlay — atmospheric depth, declared once.
     soft-light blend so the same texture reads on both
     dark navy AND light sky surfaces without being heavy. ===== */
  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.55;
    mix-blend-mode: soft-light;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch' seed='3'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    background-size: 180px 180px;
  }

  @media (prefers-reduced-motion: reduce) {
    body::after {
      opacity: 0.35;
    }
  }
</style>
