---
import { Watch } from "@lucide/astro";
import { WEAR_RELEASE } from "../config/apkRelease";

const codeClass =
  "font-mono text-sm text-cobalt bg-ink-2 px-2 py-1 rounded-[4px]";

const steps = [
  {
    number: "01",
    body: "Enable Developer Mode in your Galaxy Watch settings.",
  },
  {
    number: "02",
    body: `Pair the watch with <code class="${codeClass}">adb</code> over Wi-Fi using its companion app.`,
  },
  {
    number: "03",
    body: `Sideload the Wear APK via <code class="${codeClass}">adb install wear-release.apk</code>.`,
  },
  {
    number: "04",
    body: "Open Pacebeats on your watch and grant permissions.",
  },
];
---

<section
  id="wear"
  class="relative isolate overflow-hidden bg-ink"
  aria-labelledby="wear-heading"
  itemscope
  itemtype="https://schema.org/SoftwareApplication"
>
  <!-- Background image + solid ink overlay -->
  <img
    src="/wear1.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    decoding="async"
  />
  <div class="absolute inset-0 bg-ink/[0.80]" aria-hidden="true"></div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 py-32 md:py-40"
  >
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">
      <!-- LEFT COLUMN — eyebrow, chip, headline, body, CTA -->
      <div class="md:col-span-6 flex flex-col gap-8">
        <div class="flex flex-col gap-4">
          <span
            class="chip inline-flex items-center gap-2"
            role="status"
            aria-live="polite"
          >
            <span class="pulse-dot" aria-hidden="true"></span>
            AVAILABLE NOW · {WEAR_RELEASE.version}
          </span>
          <p
            class="font-mono text-paper-2 text-xs uppercase tracking-[0.18em]"
          >
            / 07 — COMPANION
          </p>
        </div>

        <h2
          id="wear-heading"
          class="reveal-words font-display font-extrabold text-paper"
          style="font-size: clamp(2.5rem, 6vw, 6rem); line-height: 0.9; letter-spacing: -0.02em;"
          itemprop="name"
        >
          <span class="word">Wear</span>{" "}
          <span class="word text-cobalt">the</span>{" "}
          <span class="word text-cobalt">run.</span>
        </h2>

        <p
          class="font-display font-semibold text-paper-2 tracking-[-0.01em] text-lg md:text-xl"
        >
          Pacebeats companion for Wear OS
        </p>

        <p
          class="font-body text-paper-2 max-w-[50ch] text-base md:text-lg leading-relaxed"
          itemprop="description"
        >
          Glance pace, cadence, and music sync from your Galaxy Watch. No phone
          required mid-run.
        </p>

        <div class="flex flex-col gap-5 mt-2">
          <a
            href={WEAR_RELEASE.downloadUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-cta btn-cta--primary w-full md:w-auto self-start"
            aria-label={`Download Pacebeats Wear OS APK version ${WEAR_RELEASE.version} in a new tab`}
          >
            <Watch class="w-5 h-5" aria-hidden="true" strokeWidth={2} />
            DOWNLOAD Wear APK
          </a>

          <a
            href="/docs/GALAXY_WATCH_INSTALLATION.md"
            class="link-underline font-display font-bold tracking-[0.04em] text-sm text-paper self-start"
          >
            INSTALLATION GUIDE →
          </a>
        </div>

        <p
          class="font-mono text-paper-2 text-xs uppercase tracking-[0.08em] mt-2"
        >
          {WEAR_RELEASE.version} · {WEAR_RELEASE.fileSize} · UPDATED{" "}
          {WEAR_RELEASE.updatedAt.toUpperCase()}
        </p>
      </div>

      <!-- RIGHT COLUMN — HOW TO CONNECT IT -->
      <div class="md:col-span-6 md:col-start-7">
        <h3
          class="font-display font-bold text-paper text-2xl mb-8 tracking-[-0.01em]"
        >
          HOW TO CONNECT IT.
        </h3>

        <ol class="flex flex-col" role="list">
          {
            steps.map((step, i) => (
              <li
                class={`grid grid-cols-[3rem_1fr] gap-6 ${i === 0 ? "pt-0" : "border-t border-ink-3 pt-6"} pb-6`}
              >
                <span class="font-mono text-cobalt text-xs tracking-[0.18em] pt-1">
                  {step.number}
                </span>
                <p
                  class="font-body text-paper text-base leading-relaxed"
                  set:html={step.body}
                />
              </li>
            ))
          }
        </ol>
      </div>
    </div>

    <!-- Hidden content for SEO -->
    <div class="sr-only">
      <h3>Pacebeats Wear OS Companion Features</h3>
      <ul itemprop="featureList">
        <li>Real-time pace feedback on your wrist</li>
        <li>Adaptive music control without phone interaction</li>
        <li>Recovery insights and heart rate monitoring</li>
        <li>Seamless smartwatch synchronization</li>
        <li>Hands-free running experience</li>
      </ul>
      <div itemprop="operatingSystem">Wear OS</div>
      <div itemprop="applicationSubCategory">Smartwatch Companion App</div>
      <div itemprop="softwareVersion">{WEAR_RELEASE.version}</div>
      <div itemprop="downloadUrl">{WEAR_RELEASE.downloadUrl}</div>
      <div itemprop="releaseNotes">
        Wear OS companion app released as APK download
      </div>
    </div>
  </div>
</section>

<!-- JSON-LD Structured Data for Wear OS Companion -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MobileApplication",
  "name": "Pacebeats Wear OS Companion",
  "description":
    "Wear OS smartwatch companion for Pacebeats featuring real-time pace feedback, adaptive music control, and cadence monitoring on your wrist.",
  "operatingSystem": "Wear OS",
  "applicationCategory": "HealthApplication",
  "applicationSubCategory": "Smartwatch Companion App",
  "featureList": [
    "Real-time pace feedback on your wrist",
    "Adaptive music control without phone interaction",
    "Cadence and heart-rate monitoring",
    "Seamless smartwatch synchronization",
    "Hands-free running experience",
  ],
  "downloadUrl": WEAR_RELEASE.downloadUrl,
  "softwareVersion": WEAR_RELEASE.version,
  "fileSize": WEAR_RELEASE.fileSize,
  "datePublished": WEAR_RELEASE.updatedAt,
  "releaseNotes":
    "Pacebeats Wear OS companion available as direct APK download.",
  "isPartOf": {
    "@type": "SoftwareApplication",
    "name": "Pacebeats",
    "url": "https://www.pacebeats.top",
  },
  "audience": {
    "@type": "Audience",
    "audienceType": "Smartwatch users and running enthusiasts",
  },
})} />

<script>
  // On-scroll reveal for the headline words.
  if (typeof window !== "undefined") {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    if (!prefersReducedMotion && "IntersectionObserver" in window) {
      const targets = document.querySelectorAll<HTMLElement>(
        "#wear .reveal-words"
      );
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.25, rootMargin: "0px 0px -10% 0px" }
      );
      targets.forEach((el) => io.observe(el));
    } else {
      document
        .querySelectorAll<HTMLElement>("#wear .reveal-words")
        .forEach((el) => el.classList.add("is-visible"));
    }
  }
</script>
