---
import {
    Smartphone,
    Code2,
    Music2,
    Watch,
    Rocket,
    Atom,
    FileCode2,
    Palette,
    Database,
    Activity,
} from "@lucide/astro";

// Editorial Athletic — Techstack
// Logo wall (marquee) + spec sheet of the actual stack powering Pacebeats.
// All items render as `icon + uppercase wordmark` for consistency. No brand-color SVGs.

type TechItem = {
    name: string;
    Icon: typeof Smartphone;
    desc: string;
};

const TECH: TechItem[] = [
    {
        name: "Android",
        Icon: Smartphone,
        desc: "Native runtime — built for the device in your pocket.",
    },
    {
        name: "Kotlin",
        Icon: Code2,
        desc: "100% Kotlin codebase. Null-safe, coroutine-driven.",
    },
    {
        name: "Spotify",
        Icon: Music2,
        desc: "Web API + playback SDK powering pace-synced music.",
    },
    {
        name: "Samsung Galaxy Watch",
        Icon: Watch,
        desc: "Wear OS companion app — pulse, pace, and music on your wrist.",
    },
    {
        name: "Samsung Health",
        Icon: Activity,
        desc: "Cadence, heart-rate, and Inter-Beat Interval analysis from the watch.",
    },
    {
        name: "Astro",
        Icon: Rocket,
        desc: "Ships the marketing site as static HTML with islands.",
    },
    {
        name: "React",
        Icon: Atom,
        desc: "Hydrated islands for the interactive surfaces only.",
    },
    {
        name: "TypeScript",
        Icon: FileCode2,
        desc: "End-to-end type safety across web and mobile.",
    },
    {
        name: "Tailwind CSS",
        Icon: Palette,
        desc: "Design tokens compiled in — no runtime CSS-in-JS.",
    },
    {
        name: "Firebase",
        Icon: Database,
        desc: "Auth, telemetry, and crash reporting for the mobile app.",
    },
];

// Duplicate the row inside the track so the marquee loops seamlessly.
const MARQUEE_ROW = [...TECH, ...TECH];
---

<section
    id="techstack"
    class="bg-ink text-paper py-32 md:py-40"
    aria-labelledby="techstack-heading"
    itemscope
    itemtype="https://schema.org/SoftwareApplication"
>
    <div class="max-w-7xl mx-auto px-6 md:px-10">
        <!-- Eyebrow + heading -->
        <header class="mb-16 md:mb-24">
            <div class="flex items-baseline gap-4 mb-6">
                <span
                    class="font-mono text-paper-2 text-xs uppercase tracking-[0.18em]"
                    aria-hidden="true"
                >/ 09 — UNDER THE HOOD</span>
            </div>
            <h2
                id="techstack-heading"
                class="reveal-words font-display font-extrabold text-paper leading-[0.95] tracking-[-0.02em]"
                style="font-size: clamp(2.5rem, 5vw, 5rem);"
                itemprop="name"
            >
                <span class="word">Built</span>
                {" "}
                <span class="word"><span class="text-cobalt">on</span>.</span>
            </h2>
            <p class="sr-only" itemprop="description">
                The technology stack powering Pacebeats: Android, Kotlin, Spotify,
                Samsung Galaxy Watch, Samsung Health, Astro, React, TypeScript,
                Tailwind CSS, and Firebase.
            </p>
        </header>

        <!-- Logo wall — pure-CSS marquee, hover-pause, masked edges -->
        <div
            class="marquee border-y border-ink-3 py-8"
            role="region"
            aria-label="Technology logo wall"
        >
            <div class="marquee-track">
                {
                    MARQUEE_ROW.map((tech) => (
                        <div class="group flex items-center gap-3 px-6">
                            <tech.Icon
                                class="w-5 h-5 text-paper-2 group-hover:text-paper transition-colors duration-200"
                                stroke-width="2"
                                aria-hidden="true"
                            />
                            <span class="font-display font-semibold tracking-[0.04em] text-paper-2 group-hover:text-paper transition-colors duration-200">
                                {tech.name}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Spec sheet — 2-column list of the same techs with one-line descriptions -->
        <div class="mt-24 md:mt-32" role="region" aria-label="Technology spec sheet">
            <div class="flex items-baseline justify-between mb-8">
                <span
                    class="font-mono text-paper-2 text-xs uppercase tracking-[0.18em]"
                >SPEC SHEET</span>
                <span
                    class="font-mono text-paper-2 text-xs uppercase tracking-[0.18em]"
                >10 / 10</span>
            </div>

            <dl class="grid grid-cols-1">
                {
                    TECH.map((tech, idx) => (
                        <div
                            class={`grid grid-cols-12 gap-4 md:gap-8 py-6 border-t border-ink-3${idx === TECH.length - 1 ? " border-b border-ink-3" : ""}`}
                            itemprop="technology"
                            itemscope
                            itemtype="https://schema.org/SoftwareSourceCode"
                        >
                            <dt class="col-span-12 md:col-span-4 flex items-center gap-3">
                                <span
                                    class="font-mono text-paper-2 text-xs"
                                    aria-hidden="true"
                                >
                                    {String(idx + 1).padStart(2, "0")}
                                </span>
                                <tech.Icon
                                    class="w-4 h-4 text-cobalt"
                                    stroke-width="2"
                                    aria-hidden="true"
                                />
                                <span
                                    class="font-display font-semibold tracking-[0.02em] text-paper text-lg md:text-xl"
                                    itemprop="name"
                                >
                                    {tech.name}
                                </span>
                            </dt>
                            <dd
                                class="col-span-12 md:col-span-8 font-body text-paper-2 leading-relaxed"
                                itemprop="description"
                            >
                                {tech.desc}
                            </dd>
                        </div>
                    ))
                }
            </dl>
        </div>

        <!-- SEO microdata -->
        <div class="sr-only">
            <div itemprop="programmingLanguage">Kotlin</div>
            <div itemprop="operatingSystem">Android, Wear OS</div>
            <div itemprop="applicationFramework">Jetpack Compose, Astro, React</div>
            <div itemprop="softwareRequirements">Android 7.0+ (API level 24)</div>
            <meta itemprop="codeRepository" content="https://github.com/KpG782/pacebeats-release-files" />
            <meta itemprop="runtimePlatform" content="Android Runtime (ART)" />
        </div>
    </div>
</section>

<!-- JSON-LD Structured Data for Technical Stack -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Pacebeats Technical Architecture",
    "description": "Pacebeats is built on Android, Kotlin, Spotify, Samsung Galaxy Watch, Samsung Health, Astro, React, TypeScript, Tailwind CSS, and Firebase.",
    "programmingLanguage": "Kotlin",
    "operatingSystem": "Android",
    "applicationFramework": "Jetpack Compose",
    "softwareRequirements": "Android 7.0+ (API level 24)",
    "codeRepository": "https://github.com/KpG782/pacebeats-release-files",
    "runtimePlatform": "Android Runtime (ART)",
    "softwareVersion": "1.0.0",
    "applicationCategory": "HealthApplication",
    "technology": [
        { "@type": "SoftwareSourceCode", "name": "Android",      "description": "Native runtime for the mobile app." },
        { "@type": "SoftwareSourceCode", "name": "Kotlin",       "description": "Primary language. Null-safe, coroutine-driven." },
        { "@type": "SoftwareSourceCode", "name": "Spotify",      "description": "Web API and playback SDK for pace-synced music." },
        { "@type": "SoftwareSourceCode", "name": "Samsung Galaxy Watch", "description": "Wear OS companion app — pulse, pace, and music on your wrist." },
        { "@type": "SoftwareSourceCode", "name": "Samsung Health",       "description": "Cadence, heart-rate, and Inter-Beat Interval analysis." },
        { "@type": "SoftwareSourceCode", "name": "Astro",        "description": "Static-first marketing site framework." },
        { "@type": "SoftwareSourceCode", "name": "React",        "description": "Interactive islands hydrated on demand." },
        { "@type": "SoftwareSourceCode", "name": "TypeScript",   "description": "End-to-end type safety." },
        { "@type": "SoftwareSourceCode", "name": "Tailwind CSS", "description": "Utility-first CSS, design tokens compiled in." },
        { "@type": "SoftwareSourceCode", "name": "Firebase",     "description": "Auth, telemetry, and crash reporting." }
    ]
}
</script>

<script>
    // Reveal H2 words once the section enters viewport.
    if ("IntersectionObserver" in window) {
        const headings = document.querySelectorAll<HTMLElement>(
            "#techstack .reveal-words"
        );
        const io = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("is-visible");
                        io.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.15 }
        );
        headings.forEach((h) => io.observe(h));
    } else {
        document
            .querySelectorAll<HTMLElement>("#techstack .reveal-words")
            .forEach((el) => el.classList.add("is-visible"));
    }
</script>
