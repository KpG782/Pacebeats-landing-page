---
import HeroClient from './client/HeroClient';
import { APK_RELEASE } from '../config/apkRelease';

// Headline words server-rendered so the client island only toggles `.is-visible`.
const HEADLINE_LINE_1 = "Run to the rhythm.".split(" ");
const HEADLINE_LINE_2 = "Achieve your pace.".split(" ");

const releaseCaption = `${APK_RELEASE.version} · UPDATED ${APK_RELEASE.updatedAt.toUpperCase()}`;
---

<main id="main-content" role="main">
  <section
    id="hero"
    class="relative isolate min-h-screen overflow-hidden bg-sky text-ink-on-sky"
    aria-labelledby="hero-heading"
    itemscope
    itemtype="https://schema.org/SoftwareApplication"
  >
    {/* Parallax background photo — silhouette only, very low opacity. */}
    <div
      class="hero-bg absolute inset-0 -z-20 will-change-transform opacity-[0.12]"
      aria-hidden="true"
    >
      <img
        src="/hero-section2.jpg"
        alt=""
        class="w-full h-[120%] object-cover object-center"
        loading="eager"
        decoding="async"
      />
    </div>

    {/* Sky tint overlay softens the photo into the surface. */}
    <div class="absolute inset-0 -z-10 bg-sky/[0.6]" aria-hidden="true"></div>

    {/* Route silhouette — a single GPS-style curve drawing itself
        across the hero. Sits above the overlay, below the content. */}
    <svg
      class="hero-route absolute inset-x-0 top-[18%] w-full h-[64%] pointer-events-none"
      viewBox="0 0 1440 480"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <path
        class="route-draw"
        d="M-20,300 C160,160 320,420 520,280 S880,140 1040,300 S1280,440 1460,200"
        fill="none"
        stroke="var(--color-cobalt)"
        stroke-width="1.5"
        stroke-opacity="0.32"
        stroke-linecap="round"
        stroke-linejoin="round"
        pathLength="1"
      />
      {/* Two small mile markers along the path for editorial detail. */}
      <circle cx="520" cy="280" r="3" fill="var(--color-cobalt)" opacity="0.45" />
      <circle cx="1040" cy="300" r="3" fill="var(--color-cobalt)" opacity="0.45" />
    </svg>

    {/* Content — depth plane 3 (1.0x, no parallax transform). */}
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 pt-32 md:pt-40 pb-32 md:pb-40">
      <div class="mb-10 md:mb-16 flex items-center justify-between">
        <p class="font-mono text-slate text-xs tracking-[0.18em] uppercase">
          / 01 — Mobile Application
        </p>
        <p class="hidden md:block font-mono text-slate text-xs tracking-[0.18em] uppercase">
          Pacebeats Case Study
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 items-center">
        {/* Text column — cols 1–7 on desktop */}
        <div class="md:col-span-7">
          <h1
            id="hero-heading"
            class="hero-headline reveal-words font-display font-extrabold text-ink-on-sky"
            itemprop="name"
          >
            <span class="block">
              {HEADLINE_LINE_1.map((word, i) => (
                <>
                  <span class="word">{word}</span>{i < HEADLINE_LINE_1.length - 1 ? " " : ""}
                </>
              ))}
            </span>
            <span class="block text-cobalt">
              {HEADLINE_LINE_2.map((word, i) => (
                <>
                  <span class="word">{word}</span>{i < HEADLINE_LINE_2.length - 1 ? " " : ""}
                </>
              ))}
            </span>
          </h1>

          <p
            class="mt-8 font-body text-slate max-w-[55ch] hero-subtitle"
            itemprop="description"
          >
            An Android + Wear OS running companion that adapts your music to your stride in real time. No more clashing tempos. No more skipping tracks mid-stride.
          </p>

          {/* Client island owns CTAs + scroll indicator + headline reveal trigger. */}
          <HeroClient client:load />

          <p class="mt-6 font-mono uppercase text-xs tracking-[0.18em] text-slate">
            {releaseCaption}
          </p>
        </div>

        {/* Phone visual — cols 8–12 on desktop. Parallax depth plane 2 (0.7x).
            Wrapper sets perspective; .hero-phone gets scroll-driven rotateY
            via --scroll-y (preserve-3d so children render in the 3D space). */}
        <div class="md:col-span-5 flex justify-center md:justify-end">
          <div class="hero-phone-wrap phone-3d">
            <div class="hero-phone phone-3d border border-sky-3 p-2 bg-paper rounded-[28px] shadow-[0_30px_60px_-20px_rgba(11,20,38,0.25)]">
              <img
                src="/hero-screen-1.svg"
                alt="Pacebeats mobile app interface showing pace tracking and music sync"
                class="block w-44 sm:w-52 md:w-60 lg:w-72 h-auto rounded-[20px] bg-cobalt"
                loading="eager"
                width="320"
                height="640"
              />
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Hidden SEO content (preserved). */}
    <div class="sr-only">
      <h2>Key Features of Pacebeats Running App</h2>
      <ul>
        <li itemprop="featureList">Real-time pace tracking and analytics</li>
        <li itemprop="featureList">Smart music synchronization with running cadence</li>
        <li itemprop="featureList">Spotify integration for seamless music experience</li>
        <li itemprop="featureList">Smartwatch companion app support</li>
        <li itemprop="featureList">Community challenges and social features</li>
        <li itemprop="featureList">Personalized training plans and goals</li>
      </ul>
      <div itemprop="applicationCategory">Health & Fitness</div>
      <div itemprop="operatingSystem">Android, Wear OS</div>
      <meta itemprop="offers" content="Free download" />
      <meta itemprop="url" content="https://www.pacebeats.top" />
    </div>

    {/* Image attribution — discreet hairline link. */}
    <p class="absolute bottom-2 right-3 z-10 font-mono text-[0.6rem] uppercase tracking-[0.14em] text-slate/70">
      Photo:{" "}
      <a
        href="https://unsplash.com/@slelham?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText"
        target="_blank"
        rel="noopener noreferrer"
        class="link-underline text-slate hover:text-ink-on-sky"
      >Steven Lelham</a>
      {" / "}
      <a
        href="https://unsplash.com/photos/group-of-people-running-on-stadium-atSaEOeE8Nk?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText"
        target="_blank"
        rel="noopener noreferrer"
        class="link-underline text-slate hover:text-ink-on-sky"
      >Unsplash</a>
    </p>
  </section>
</main>

