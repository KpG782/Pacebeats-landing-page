<style>
  /* Hero headline scale — Plus Jakarta Sans 800. Jakarta is wider than the
     condensed face it replaced, so we shrink top of clamp and breathe out
     line-height a touch. */
  .hero-headline {
    font-size: clamp(2.75rem, 6.5vw, 6.25rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    text-transform: none;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 1.2vw, 1.25rem);
    line-height: 1.5;
  }

  /* Parallax: the inline JS below writes --scroll-y on this section root.
     Three depth planes — bg 0.3x, phone-wrap 0.7x, content 1.0x. */
  .hero-bg {
    transform: translate3d(0, calc(var(--scroll-y, 0) * -0.3px), 0);
  }
  .hero-phone-wrap {
    perspective: 1400px;
    transform: translate3d(0, calc(var(--scroll-y, 0) * -0.7px), 0);
  }
  /* Phone gains scroll-driven rotateY — from -6deg at top to ~+2deg as
     hero scrolls out. Static rotateX keeps the top edge tilted back. */
  .hero-phone {
    transform:
      rotateY(calc(-6deg + var(--scroll-y, 0) * 0.008deg))
      rotateX(2deg);
  }

  /* Reduced motion: never translate, never tilt-on-scroll. */
  @media (prefers-reduced-motion: reduce) {
    .hero-bg,
    .hero-phone-wrap {
      transform: none !important;
    }
    .hero-phone {
      transform: rotateY(-6deg) rotateX(2deg) !important;
    }
  }
</style>

<script>
  // ─────────────────────────────────────────────────────────────
  // Hero parallax — single rAF loop, writes --scroll-y on the
  // hero section. Two children consume it via CSS transforms.
  // Gated on prefers-reduced-motion + only runs when hero is in view.
  // ─────────────────────────────────────────────────────────────
  (() => {
    const hero = document.getElementById('hero');
    if (!hero) return;

    const prefersReduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;
    if (prefersReduced) return;

    let rafId: number | null = null;
    let inView = false;

    const tick = () => {
      hero.style.setProperty('--scroll-y', String(window.scrollY));
      if (inView) {
        rafId = window.requestAnimationFrame(tick);
      } else {
        rafId = null;
      }
    };

    const start = () => {
      if (rafId !== null) return;
      rafId = window.requestAnimationFrame(tick);
    };
    const stop = () => {
      if (rafId !== null) {
        window.cancelAnimationFrame(rafId);
        rafId = null;
      }
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            inView = entry.isIntersecting;
            if (inView) start();
            else stop();
          }
        },
        { threshold: 0 },
      );
      io.observe(hero);
    } else {
      // Fallback — always-on rAF.
      inView = true;
      start();
    }
  })();
</script>
