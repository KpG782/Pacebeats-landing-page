---
---

<section id="support" class="bg-ink text-paper py-32 md:py-40 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="max-w-3xl mb-20">
      <p class="font-mono text-xs tracking-[0.18em] uppercase text-paper-2 mb-6">/ SUPPORT</p>
      <h2
        class="font-display font-bold tracking-[-0.02em] text-paper"
        style="font-size: clamp(2rem, 4.5vw, 5rem); line-height: 0.95;"
      >
        Support &amp; Help
      </h2>
      <span class="reveal-line is-visible block w-16 mt-6 text-cobalt" aria-hidden="true"></span>
      <p class="font-body text-paper-2 text-base md:text-lg leading-[1.6] mt-8 max-w-[60ch]">
        Get the most out of Pacebeats with our guides and troubleshooting resources.
      </p>
    </div>

    <!-- Support card grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-24">
      <!-- Getting Started -->
      <article class="card-hairline p-8">
        <svg
          class="w-6 h-6 text-cobalt mb-6"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </svg>
        <h3 class="font-display font-bold text-paper text-xl mb-5 tracking-[-0.005em]">
          Getting Started
        </h3>
        <ul class="space-y-3 font-body text-sm text-paper-2 leading-[1.6]">
          <li>Setting up your Galaxy Watch connection</li>
          <li>Granting Samsung Health permissions</li>
          <li>Creating your first workout profile</li>
          <li>Understanding heart rate zones</li>
        </ul>
      </article>

      <!-- Troubleshooting -->
      <article class="card-hairline p-8">
        <svg
          class="w-6 h-6 text-cobalt mb-6"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
        </svg>
        <h3 class="font-display font-bold text-paper text-xl mb-5 tracking-[-0.005em]">
          Troubleshooting
        </h3>
        <ul class="space-y-3 font-body text-sm text-paper-2 leading-[1.6]">
          <li>Watch not connecting to phone</li>
          <li>Heart rate data not syncing</li>
          <li>GPS accuracy issues</li>
          <li>Battery optimization settings</li>
        </ul>
      </article>

      <!-- Contact & Resources -->
      <article class="card-hairline p-8">
        <svg
          class="w-6 h-6 text-cobalt mb-6"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
        <h3 class="font-display font-bold text-paper text-xl mb-5 tracking-[-0.005em]">
          Contact &amp; Resources
        </h3>
        <ul class="space-y-3 font-body text-sm text-paper-2 leading-[1.6]">
          <li>
            <a
              href="https://github.com/KpG782/pacebeats-release-files"
              class="link-underline text-paper hover:text-cobalt-3"
              target="_blank"
              rel="noopener"
            >GitHub Release Files</a>
          </li>
          <li>Email: support@pacebeats.app</li>
          <li>Community Discord (Coming Soon)</li>
          <li>Samsung Health SDK Guide</li>
        </ul>
      </article>
    </div>

    <!-- FAQ -->
    <div class="mb-24">
      <div class="mb-12">
        <p class="font-mono text-xs tracking-[0.18em] uppercase text-paper-2 mb-4">/ FAQ</p>
        <h3
          class="font-display font-bold tracking-[-0.02em] text-paper"
          style="font-size: clamp(1.75rem, 3.5vw, 3rem); line-height: 0.95;"
        >
          Frequently Asked Questions
        </h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <article class="card-hairline p-6">
          <h4 class="font-display font-bold text-paper text-lg mb-3 tracking-[-0.005em]">
            Which devices are compatible with Pacebeats?
          </h4>
          <p class="font-body text-paper-2 text-sm leading-[1.6]">
            Pacebeats works with Galaxy Watch 5, 6, and 7, paired with Android devices running Android 7.0 or higher.
            Samsung Health app must be installed and configured.
          </p>
        </article>

        <article class="card-hairline p-6">
          <h4 class="font-display font-bold text-paper text-lg mb-3 tracking-[-0.005em]">
            How accurate is the heart rate monitoring?
          </h4>
          <p class="font-body text-paper-2 text-sm leading-[1.6]">
            Pacebeats uses Samsung Health's advanced algorithms with Inter-Beat Interval (IBI) analysis for
            precision tracking, providing professional-grade accuracy for your workouts.
          </p>
        </article>

        <article class="card-hairline p-6">
          <h4 class="font-display font-bold text-paper text-lg mb-3 tracking-[-0.005em]">
            Can I use Pacebeats without a Galaxy Watch?
          </h4>
          <p class="font-body text-paper-2 text-sm leading-[1.6]">
            Currently, Pacebeats is designed specifically for Samsung Galaxy Watch integration.
            Phone-only functionality is planned for future releases.
          </p>
        </article>

        <article class="card-hairline p-6">
          <h4 class="font-display font-bold text-paper text-lg mb-3 tracking-[-0.005em]">
            When will Pacebeats be available for download?
          </h4>
          <p class="font-body text-paper-2 text-sm leading-[1.6]">
            Pacebeats is currently in active development. Follow our GitHub repository for the latest
            updates and beta release announcements.
          </p>
        </article>
      </div>
    </div>

    <!-- System Requirements -->
    <div class="card-hairline p-8 md:p-10">
      <p class="font-mono text-xs tracking-[0.18em] uppercase text-paper-2 mb-4">/ SPEC SHEET</p>
      <h3 class="font-display font-bold text-paper text-2xl md:text-3xl mb-10 tracking-[-0.01em]">
        System Requirements
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div>
          <h4 class="font-display font-bold text-cobalt text-base mb-4 tracking-[0.02em]">
            Android Device
          </h4>
          <ul class="space-y-2 font-body text-paper-2 text-sm leading-[1.6]">
            <li>Android 7.0 or higher</li>
            <li>4GB RAM minimum</li>
            <li>100MB storage space</li>
            <li>Bluetooth 4.0+</li>
          </ul>
        </div>
        <div>
          <h4 class="font-display font-bold text-cobalt text-base mb-4 tracking-[0.02em]">
            Galaxy Watch
          </h4>
          <ul class="space-y-2 font-body text-paper-2 text-sm leading-[1.6]">
            <li>Galaxy Watch 5, 6, or 7</li>
            <li>Latest firmware update</li>
            <li>Samsung Health installed</li>
            <li>Active Samsung account</li>
          </ul>
        </div>
        <div>
          <h4 class="font-display font-bold text-cobalt text-base mb-4 tracking-[0.02em]">
            Permissions
          </h4>
          <ul class="space-y-2 font-body text-paper-2 text-sm leading-[1.6]">
            <li>Location (for GPS tracking)</li>
            <li>Health data access</li>
            <li>Bluetooth connectivity</li>
            <li>Storage (for workout logs)</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
