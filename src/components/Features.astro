---
// Features — Editorial Athletic bento grid.
// Astro shell owns the section frame, SEO/JSON-LD, sr-only.
// The React island (FeaturesClient) owns the card grid + on-scroll reveal.
import FeaturesClient from "./client/FeaturesClient";
---

<section
    id="features"
    class="bg-sky text-ink-on-sky py-32 md:py-40"
    aria-labelledby="features-heading"
    itemscope
    itemtype="https://schema.org/ItemList"
>
    <div class="max-w-7xl mx-auto px-6 md:px-10">
        <!-- Section header -->
        <header class="mb-16 md:mb-20">
            <p
                class="font-mono text-slate text-xs tracking-[0.18em] uppercase mb-6"
            >
                / 03 — Capabilities
            </p>
            <h2
                id="features-heading"
                class="font-display font-bold text-ink-on-sky max-w-5xl"
                style="font-size: clamp(2.5rem, 5vw, 5rem); line-height: 0.95; letter-spacing: -0.02em;"
                itemprop="name"
            >
                <span class="block">
                    Built for the way <span class="text-cobalt">you run</span>.
                </span>
            </h2>
            <p class="sr-only" itemprop="description">
                Four core capabilities — smart pace detection, night-run-ready
                visuals, offline reliability, and the Wear OS companion.
            </p>
        </header>

        <!-- Bento grid lives in the React island -->
        <FeaturesClient client:visible />
    </div>
</section>

<!-- JSON-LD Structured Data for Features -->
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": "Pacebeats App Features",
        "description": "Core capabilities of the Pacebeats running application",
        "numberOfItems": 4,
        "itemListElement": [
            {
                "@type": "SoftwareFeature",
                "position": 1,
                "name": "Smart Pace Detection",
                "description": "Cadence-aware playback that shifts music in real time to match your stride.",
                "featureType": "Pace Intelligence"
            },
            {
                "@type": "SoftwareFeature",
                "position": 2,
                "name": "Night-Run Ready",
                "description": "High-contrast layouts and single-tap controls tuned for low-light visibility.",
                "featureType": "Accessibility"
            },
            {
                "@type": "SoftwareFeature",
                "position": 3,
                "name": "Offline-Friendly",
                "description": "Routes and pace cues cached locally for runs beyond signal.",
                "featureType": "Reliability"
            },
            {
                "@type": "SoftwareFeature",
                "position": 4,
                "name": "Wear OS Companion",
                "description": "Glance pace, BPM, and route from your Galaxy Watch.",
                "featureType": "Wearable Integration"
            }
        ]
    }
</script>
