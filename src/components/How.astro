---
import HowClient from "./client/HowClient";

const steps = [
  {
    number: "01",
    title: "Connect",
    body: "Pair Pacebeats with Spotify and (optionally) your Galaxy Watch.",
  },
  {
    number: "02",
    title: "Calibrate",
    body: "One short run sets your baseline cadence and pace zones.",
  },
  {
    number: "03",
    title: "RUN",
    body: "Music adapts to your stride in real time; pace targets surface as you go.",
  },
  {
    number: "04",
    title: "Review",
    body: "Post-run breakdown of pace, cadence, and music sync quality.",
  },
];

const phases = [
  {
    label: "01",
    title: "ROUTE INTELLIGENCE",
    body: "Surface familiar routes and predict pace from your history.",
    active: true,
  },
  {
    label: "02",
    title: "SOCIAL",
    body: "Shared runs and pacing leaderboards.",
    active: false,
  },
  {
    label: "03",
    title: "HEALTH",
    body: "Deeper Samsung Galaxy Watch integration — live cadence, heart-rate, and run summary streamed straight to your wrist.",
    active: false,
  },
];
---

<section
  id="how"
  class="bg-sky text-ink-on-sky py-32 md:py-40"
  aria-labelledby="how-heading"
  itemscope
  itemtype="https://schema.org/HowTo"
>
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <!-- Header -->
    <header class="flex flex-col gap-6 mb-20 md:mb-28">
      <p
        class="font-mono text-slate text-xs uppercase tracking-[0.18em]"
      >
        / 08 — THE JOURNEY
      </p>
      <h2
        id="how-heading"
        class="reveal-words font-display font-bold text-ink-on-sky max-w-[20ch]"
        style="font-size: clamp(2.5rem, 6vw, 6rem); line-height: 0.9; letter-spacing: -0.02em;"
        itemprop="name"
      >
        <span class="word">Four</span>{" "}
        <span class="word">steps.</span>{" "}
        <span class="word text-cobalt">First</span>{" "}
        <span class="word text-cobalt">run.</span>
      </h2>
      <p class="sr-only" itemprop="description">
        Complete step-by-step guide to using Pacebeats for music-synchronized
        running with pace tracking and adaptive playlists.
      </p>
    </header>

    <!-- Step list (animated by HowClient island) -->
    <HowClient client:load steps={steps} />

    <!-- Currently in Development -->
    <section
      class="mt-28 md:mt-36"
      role="region"
      aria-label="Development roadmap"
    >
      <h3
        class="font-mono uppercase text-slate tracking-[0.18em] text-xs mb-8"
      >
        CURRENTLY IN DEVELOPMENT
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          phases.map((phase) => (
            <article
              class="card-hairline-light p-6 md:p-8 flex flex-col gap-3"
              role="listitem"
            >
              <span class="font-mono text-slate text-xs tracking-[0.18em]">
                {phase.label}
              </span>
              <h4
                class={`font-display font-bold text-lg tracking-[-0.01em] ${
                  phase.active ? "text-cobalt" : "text-ink-on-sky"
                }`}
              >
                {phase.title}
              </h4>
              <p class="font-body text-slate text-sm md:text-base leading-relaxed">
                {phase.body}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Hidden content for SEO -->
    <div class="sr-only">
      <meta itemprop="totalTime" content="PT10M" />
      <meta itemprop="prepTime" content="PT2M" />
      <meta itemprop="performTime" content="PT8M" />
      <span>Estimated time: 10 minutes</span>
    </div>
  </div>
</section>

<!-- JSON-LD Structured Data for How-To Guide -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Four Steps to Your First Pacebeats Run",
  "description":
    "Four-step guide to using Pacebeats for music-synchronized running with pace tracking and adaptive playlists.",
  "totalTime": "PT10M",
  "prepTime": "PT2M",
  "performTime": "PT8M",
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": "0",
  },
  "supply": [
    { "@type": "HowToSupply", "name": "Smartphone with Pacebeats app" },
    { "@type": "HowToSupply", "name": "Running shoes and attire" },
    { "@type": "HowToSupply", "name": "Spotify account (optional)" },
    { "@type": "HowToSupply", "name": "Galaxy Watch (optional)" },
  ],
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Connect",
      "text":
        "Pair Pacebeats with Spotify and (optionally) your Galaxy Watch.",
      "url": "https://www.pacebeats.top/#how",
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Calibrate",
      "text":
        "One short run sets your baseline cadence and pace zones.",
      "url": "https://www.pacebeats.top/#how",
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Run",
      "text":
        "Music adapts to your stride in real time; pace targets surface as you go.",
      "url": "https://www.pacebeats.top/#how",
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Review",
      "text":
        "Post-run breakdown of pace, cadence, and music sync quality.",
      "url": "https://www.pacebeats.top/#how",
    },
  ],
  "about": {
    "@type": "SoftwareApplication",
    "name": "Pacebeats",
    "applicationCategory": "HealthApplication",
  },
})} />

<script>
  // On-scroll reveal for the headline words.
  if (typeof window !== "undefined") {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    if (!prefersReducedMotion && "IntersectionObserver" in window) {
      const targets = document.querySelectorAll<HTMLElement>(
        "#how .reveal-words"
      );
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.25, rootMargin: "0px 0px -10% 0px" }
      );
      targets.forEach((el) => io.observe(el));
    } else {
      document
        .querySelectorAll<HTMLElement>("#how .reveal-words")
        .forEach((el) => el.classList.add("is-visible"));
    }
  }
</script>
