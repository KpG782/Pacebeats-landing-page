---
import { Github, Linkedin } from "@lucide/astro";

// Editorial Athletic — Team
// 4-up portrait grid on a sky surface. Real bios + skill chips per member.
// Hover swaps the portrait from grayscale to color (filter only — no transforms).

type Member = {
    name: string;
    initials: string;
    role: string;
    bio: string;
    skills: [string, string, string];
    photo: string;
    photoTodo?: boolean;
    github?: string;
    linkedin?: string;
};

const MEMBERS: Member[] = [
    {
        name: "Ken Patrick Garcia",
        initials: "KG",
        role: "Lead Software Engineer",
        bio: "Oversees all technical architecture and core development. Guides the team through system design, Android innovation, and seamless integration with Samsung Galaxy Watch and health platforms.",
        skills: ["Kotlin", "Android", "Leadership"],
        photo: "/ken.jpg",
        github: "https://github.com/KpG782",
        linkedin: "https://www.linkedin.com/in/ken-patrick-garcia-ba5430285/",
    },
    {
        name: "Timothy Forte",
        initials: "TF",
        role: "UI/UX Designer",
        bio: "Frontend developer and design lead. Crafts Pacebeats' intuitive interface and ensures the running experience reads clearly at full stride — across phone and watch.",
        skills: ["UI/UX", "Frontend", "Design"],
        photo: "/ken.jpg",
        photoTodo: true,
        linkedin: "https://www.linkedin.com/in/timothy-forte-3a0512168/",
    },
    {
        name: "Brian Ashley Papa",
        initials: "BP",
        role: "AI/ML Engineer",
        bio: "Implements intelligent pace detection and personalized music adaptation. Owns the machine-learning pipeline that makes Pacebeats smarter with every run logged.",
        skills: ["Machine Learning", "Samsung Health", "Integration"],
        photo: "/ken.jpg",
        photoTodo: true,
    },
    {
        name: "Lanz Corpuz",
        initials: "LC",
        role: "Frontend Developer",
        bio: "Builds the responsive surfaces that make Pacebeats feel effortless mid-run. Owns mobile UI implementation, QA, and the end-to-end testing harness.",
        skills: ["Mobile Dev", "QA", "Testing"],
        photo: "/ken.jpg",
        photoTodo: true,
        linkedin: "https://www.linkedin.com/in/lanz-corpuz-73719b2a6/",
    },
];
---

<section
    id="team"
    class="bg-sky text-ink-on-sky py-32 md:py-40"
    aria-labelledby="team-heading"
    itemscope
    itemtype="https://schema.org/Organization"
>
    <div class="max-w-7xl mx-auto px-6 md:px-10">
        <!-- Eyebrow + heading -->
        <header class="mb-16 md:mb-20">
            <div class="flex items-baseline gap-4 mb-6">
                <span
                    class="font-mono text-slate text-xs uppercase tracking-[0.18em]"
                    aria-hidden="true"
                >/ 10 — The builders</span>
            </div>
            <h2
                id="team-heading"
                class="reveal-words font-display font-extrabold text-ink-on-sky leading-[1.0] tracking-[-0.025em]"
                style="font-size: clamp(2.5rem, 5vw, 5rem);"
                itemprop="name"
            >
                <span class="word">The</span>
                {" "}
                <span class="word"><span class="text-cobalt">team</span>.</span>
            </h2>
            <p class="sr-only" itemprop="description">
                Four people building Pacebeats — lead software engineer,
                UI/UX designer, AI/ML engineer, and frontend developer.
            </p>
        </header>

        <!-- 4-up grid -->
        <ul
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8"
            role="list"
            aria-label="Team members"
        >
            {
                MEMBERS.map((m, idx) => (
                    <li
                        class="group flex flex-col"
                        itemprop="member"
                        itemscope
                        itemtype="https://schema.org/Person"
                    >
                        {/* Portrait — real photo OR initials fallback when TODO. */}
                        <div class="relative aspect-[4/5] border border-sky-3 overflow-hidden bg-paper p-2 rounded-[12px] shadow-[0_8px_24px_-8px_rgba(11,20,38,0.15)]">
                            {m.photoTodo ? (
                                <div
                                    class="w-full h-full rounded-[8px] bg-gradient-to-br from-sky-2 to-sky flex items-center justify-center"
                                    aria-hidden="true"
                                >
                                    <span class="font-display font-extrabold text-cobalt text-6xl tracking-[-0.04em] select-none">
                                        {m.initials}
                                    </span>
                                </div>
                            ) : (
                                <img
                                    src={m.photo}
                                    alt={`${m.name} — ${m.role}`}
                                    loading="lazy"
                                    decoding="async"
                                    width="400"
                                    height="500"
                                    class="w-full h-full rounded-[8px] object-cover grayscale group-hover:grayscale-0 transition-[filter] duration-300 ease-out-quart"
                                    itemprop="image"
                                />
                            )}
                            {m.photoTodo && (
                                <span class="sr-only">
                                    Portrait pending — {m.name}
                                </span>
                            )}
                        </div>

                        {/* Index + role */}
                        <div class="flex items-baseline justify-between mt-5">
                            <span class="font-mono text-slate text-xs tracking-[0.18em]">
                                {String(idx + 1).padStart(2, "0")} / 04
                            </span>
                            <span
                                class="font-mono text-slate text-xs uppercase tracking-[0.12em]"
                                itemprop="jobTitle"
                            >
                                {m.role}
                            </span>
                        </div>

                        {/* Name */}
                        <h3 class="mt-2">
                            <span
                                class="link-underline font-display font-bold text-ink-on-sky text-xl md:text-[1.35rem] tracking-[-0.015em] leading-tight"
                                itemprop="name"
                            >
                                {m.name}
                            </span>
                        </h3>

                        {/* Bio */}
                        <p
                            class="mt-3 font-body text-slate text-sm leading-relaxed"
                            itemprop="description"
                        >
                            {m.bio}
                        </p>

                        {/* Skill chips */}
                        <ul
                            class="mt-4 flex flex-wrap gap-1.5"
                            role="list"
                            aria-label={`${m.name} — skills`}
                        >
                            {m.skills.map((s) => (
                                <li
                                    class="inline-flex items-center font-mono text-[0.65rem] uppercase tracking-[0.12em] text-cobalt-2 border border-sky-3 bg-paper px-2 py-1 rounded-full"
                                    itemprop="knowsAbout"
                                >
                                    {s}
                                </li>
                            ))}
                        </ul>

                        {/* Social — pushed to bottom of card via flex */}
                        {(m.github || m.linkedin) && (
                            <div class="mt-auto pt-5 flex items-center gap-3">
                                {m.github && (
                                    <a
                                        href={m.github}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center justify-center w-8 h-8 rounded-full border border-sky-3 bg-paper text-slate hover:text-cobalt hover:border-cobalt transition-colors duration-200"
                                        aria-label={`${m.name} on GitHub — opens in new tab`}
                                        itemprop="sameAs"
                                    >
                                        <Github
                                            class="w-4 h-4"
                                            stroke-width="2"
                                            aria-hidden="true"
                                        />
                                    </a>
                                )}
                                {m.linkedin && (
                                    <a
                                        href={m.linkedin}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center justify-center w-8 h-8 rounded-full border border-sky-3 bg-paper text-slate hover:text-cobalt hover:border-cobalt transition-colors duration-200"
                                        aria-label={`${m.name} on LinkedIn — opens in new tab`}
                                        itemprop="sameAs"
                                    >
                                        <Linkedin
                                            class="w-4 h-4"
                                            stroke-width="2"
                                            aria-hidden="true"
                                        />
                                    </a>
                                )}
                            </div>
                        )}
                    </li>
                ))
            }
        </ul>

        <!-- SEO microdata -->
        <div class="sr-only">
            <div itemprop="numberOfEmployees">4</div>
            <div itemprop="foundingLocation">University of Makati</div>
            <div itemprop="knowsAbout">
                Mobile App Development, Android Development, Running Apps, Music
                Integration, AI/ML, UX Design
            </div>
        </div>
    </div>
</section>

<!-- JSON-LD Structured Data for Team -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Pacebeats Development Team",
    "description": "Four-person team building the Pacebeats running app — lead engineer, UI/UX designer, AI/ML engineer, and frontend developer.",
    "numberOfEmployees": 4,
    "foundingLocation": {
        "@type": "Place",
        "name": "University of Makati"
    },
    "knowsAbout": [
        "Mobile App Development",
        "Android Development",
        "Running Apps",
        "Music Integration",
        "AI/ML",
        "UX Design",
        "Samsung Galaxy Watch"
    ],
    "member": [
        {
            "@type": "Person",
            "name": "Ken Patrick Garcia",
            "jobTitle": "Lead Software Engineer",
            "description": "Oversees technical architecture and core development. Guides system design, Android innovation, and Samsung Galaxy Watch integration.",
            "sameAs": [
                "https://github.com/KpG782",
                "https://www.linkedin.com/in/ken-patrick-garcia-ba5430285/"
            ],
            "knowsAbout": ["Kotlin", "Android", "Leadership"],
            "image": "https://www.pacebeats.top/ken.jpg"
        },
        {
            "@type": "Person",
            "name": "Timothy Forte",
            "jobTitle": "UI/UX Designer",
            "description": "Frontend developer and design lead. Crafts the Pacebeats interface for clarity at full stride across phone and watch.",
            "sameAs": "https://www.linkedin.com/in/timothy-forte-3a0512168/",
            "knowsAbout": ["UI/UX", "Frontend", "Design"]
        },
        {
            "@type": "Person",
            "name": "Brian Ashley Papa",
            "jobTitle": "AI/ML Engineer",
            "description": "Implements intelligent pace detection and personalized music adaptation. Owns the ML pipeline behind Pacebeats' recommendations.",
            "knowsAbout": ["Machine Learning", "Samsung Health", "Integration"]
        },
        {
            "@type": "Person",
            "name": "Lanz Corpuz",
            "jobTitle": "Frontend Developer",
            "description": "Builds responsive mobile UI surfaces and owns the QA and end-to-end testing harness.",
            "sameAs": "https://www.linkedin.com/in/lanz-corpuz-73719b2a6/",
            "knowsAbout": ["Mobile Dev", "QA", "Testing"]
        }
    ]
}
</script>
