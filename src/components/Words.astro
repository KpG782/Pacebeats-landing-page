---
// Editorial Athletic — Words
// Full-bleed typographic block. "OWN THE PACE" is the protagonist (lime, filled).
// Surrounding words are static, outlined paper or muted solid, scattered across a 12-col grid.
// No bubble UI, no hover effects, no photo, no gradient.

type Word = {
    text: string;
    /** grid placement: col-start / col-span (mobile + md) */
    col: string;
    row: string;
    /** Tailwind size class chain */
    size: string;
    /** outline | solid */
    style: "outline" | "solid";
    /** optional small rotation, in degrees */
    rotate?: number;
};

const WORDS: Word[] = [
    { text: "STRIDE",         col: "col-start-1 col-span-4",          row: "row-start-1", size: "text-3xl md:text-5xl",         style: "outline" },
    { text: "CADENCE",        col: "col-start-8 col-span-5",          row: "row-start-1", size: "text-2xl md:text-4xl",         style: "solid"   },
    { text: "BPM",            col: "col-start-2 col-span-3",          row: "row-start-2", size: "text-5xl md:text-7xl",         style: "outline" },
    { text: "TEMPO",          col: "col-start-9 col-span-4",          row: "row-start-2", size: "text-4xl md:text-6xl",         style: "outline" },
    { text: "MILE 5",         col: "col-start-1 col-span-4",          row: "row-start-3", size: "text-2xl md:text-3xl",         style: "solid"   },
    { text: "HEART",          col: "col-start-10 col-span-3",         row: "row-start-3", size: "text-3xl md:text-5xl",         style: "outline" },
    { text: "BREATH",         col: "col-start-2 col-span-4",          row: "row-start-7", size: "text-2xl md:text-4xl",         style: "outline" },
    { text: "FLOW",           col: "col-start-9 col-span-4",          row: "row-start-7", size: "text-4xl md:text-6xl",         style: "outline" },
    { text: "NEGATIVE SPLIT", col: "col-start-1 col-span-6",          row: "row-start-8", size: "text-xl md:text-2xl",          style: "solid"   },
    { text: "RUNNER",         col: "col-start-9 col-span-4",          row: "row-start-8", size: "text-3xl md:text-5xl",         style: "outline" },
    { text: "PACE ZONE",      col: "col-start-2 col-span-4",          row: "row-start-9", size: "text-2xl md:text-3xl",         style: "outline" },
    { text: "RHYTHM",         col: "col-start-8 col-span-5",          row: "row-start-9", size: "text-4xl md:text-6xl",         style: "outline" },
    { text: "KICK",           col: "col-start-1 col-span-3",          row: "row-start-10",size: "text-3xl md:text-5xl",         style: "solid"   },
    { text: "RECOVERY",       col: "col-start-9 col-span-4",          row: "row-start-10",size: "text-2xl md:text-4xl",         style: "outline" },
    { text: "MILE",           col: "col-start-6 col-span-2",          row: "row-start-1", size: "text-xl md:text-2xl",          style: "solid"   },
];
---

<section
    id="words"
    class="bg-ink text-paper py-40 md:py-56 overflow-hidden"
    aria-labelledby="words-heading"
    itemscope
    itemtype="https://schema.org/CreativeWork"
>
    <div class="max-w-[1400px] mx-auto px-6">
        <!-- Decorative typography grid — hidden from screen readers
             (the headline + sr-only description below convey the content). -->
        <div
            class="relative grid grid-cols-12 gap-x-4 md:gap-x-6"
            style="grid-auto-rows: minmax(2.5rem, auto);"
            aria-hidden="true"
        >
            {
                WORDS.map((w) => (
                    <span
                        class={`${w.col} ${w.row} ${w.size} font-display font-bold tracking-[-0.02em] leading-[0.95] self-center select-none ${w.style === "outline" ? "text-outline" : "text-paper-2"}`}
                    >
                        {w.text}
                    </span>
                ))
            }

            <!-- Protagonist: Own the pace — the real visible heading -->
            <h2
                id="words-heading"
                class="reveal-words col-start-1 col-span-12 row-start-4 row-span-3 self-center text-center font-display font-extrabold text-cobalt"
                style="font-size: clamp(5rem, 12vw, 14rem); line-height: 0.85; letter-spacing: -0.045em;"
                itemprop="headline"
            >
                <span class="word">Own</span>
                {" "}
                <span class="word">the</span>
                {" "}
                <span class="word">pace.</span>
            </h2>
        </div>

        <!-- SR-only description so screen readers get the running vocabulary
             once, semantically, instead of word-by-word from the scattered spans. -->
        <p class="sr-only" itemprop="description">
            Own the pace. Pacebeats is built around the language runners use:
            stride, cadence, BPM, tempo, mile, heart, breath, flow, negative
            split, pace zone, rhythm, kick, recovery.
        </p>
    </div>
</section>

<!-- JSON-LD Structured Data -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": "Own the Pace — Pacebeats Running Vocabulary",
    "description": "Typographic editorial block built from the language runners actually use: stride, cadence, BPM, tempo, mile, heart, breath, flow, negative split, pace zone, rhythm, kick, recovery.",
    "keywords": [
        "running", "pace", "cadence", "stride", "tempo", "BPM", "rhythm",
        "negative split", "recovery", "flow", "kick", "pace zone"
    ],
    "about": {
        "@type": "SoftwareApplication",
        "name": "Pacebeats",
        "applicationCategory": "HealthApplication"
    }
}
</script>

<script>
    if ("IntersectionObserver" in window) {
        const headings = document.querySelectorAll<HTMLElement>(
            "#words .reveal-words"
        );
        const io = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("is-visible");
                        io.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.15 }
        );
        headings.forEach((h) => io.observe(h));
    } else {
        document
            .querySelectorAll<HTMLElement>("#words .reveal-words")
            .forEach((el) => el.classList.add("is-visible"));
    }
</script>
