---
import NavbarClient from './client/NavbarClient';
import MobileMenuClient from './client/MobileMenuClient';
---

{/* Skip-to-content link — single source of truth for the whole site. */}
<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-cobalt focus:text-paper focus:px-4 focus:py-2 focus:rounded-[4px] focus:font-display focus:uppercase focus:tracking-[0.08em]"
>
  Skip to main content
</a>

<header role="banner">
  <nav
    id="site-nav"
    class="fixed top-0 left-0 right-0 z-50 w-full bg-sky/85 backdrop-blur-md text-ink-on-sky border-b border-transparent transition-[border-color] duration-300 ease-out-quart"
    role="navigation"
    aria-label="Main navigation"
    itemscope
    itemtype="https://schema.org/SiteNavigationElement"
  >
    <div class="max-w-7xl mx-auto px-6 md:px-10 h-14 md:h-16 flex items-center">
      <NavbarClient client:load />
    </div>

    <MobileMenuClient client:load />
  </nav>
</header>

<!-- JSON-LD Structured Data for SEO -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Pacebeats",
    "description": "Run to the rhythm. Achieve your pace. Pacebeats is an Android + Wear OS running companion that adapts your music to your stride in real time.",
    "url": "https://www.pacebeats.top",
    "applicationCategory": "HealthApplication",
    "operatingSystem": ["Android", "Wear OS"],
    "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
    },
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "ratingCount": "150"
    },
    "author": {
        "@type": "Organization",
        "name": "Pacebeats Team",
        "url": "https://www.pacebeats.top"
    },
    "featureList": [
        "Real-Time Pace & Analytics",
        "Smart Pace Detection",
        "Spotify Integration",
        "Smartwatch Companion",
        "Community Challenges",
        "Personalized Training Plans"
    ]
}
</script>

<script>
  // Toggle a hairline bottom border on the navbar once the user scrolls past 8px.
  const nav = document.getElementById('site-nav');
  if (nav) {
    const update = () => {
      if (window.scrollY > 8) {
        nav.classList.add('border-sky-3');
        nav.classList.remove('border-transparent');
      } else {
        nav.classList.add('border-transparent');
        nav.classList.remove('border-sky-3');
      }
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
