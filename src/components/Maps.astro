---
// Maps / Spotify integration section — Editorial Athletic restyle.
// Pure Astro: reveal animations driven by a small IntersectionObserver
// in the inline JS block below. No React island needed here.
---

<section
    id="maps"
    class="bg-ink text-paper py-32 md:py-40 relative z-10"
    aria-labelledby="maps-heading"
    itemscope
    itemtype="https://schema.org/SoftwareApplication"
>
    <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 items-center">
            <!-- Visual: cols 1–5 on md+. First in DOM so it stacks first on mobile. -->
            <div class="md:col-span-5 reveal-fade-rise" data-reveal>
                <figure class="border border-ink-3 p-2">
                    <img
                        src="/spotify.jpg"
                        alt="Pacebeats app screen showing a Spotify-powered playlist synced to a runner's cadence"
                        class="block w-full h-auto"
                        loading="lazy"
                        decoding="async"
                        width="800"
                        height="1000"
                        itemprop="screenshot"
                    />
                </figure>
            </div>

            <!-- Text: cols 7–12 on md+ (one-column gap between visual and text). -->
            <div class="md:col-span-6 md:col-start-7">
                <p
                    class="font-mono text-paper-2 text-xs tracking-[0.18em] uppercase mb-6 reveal-fade-rise"
                    data-reveal
                >
                    / 02 — Integration
                </p>

                <h2
                    id="maps-heading"
                    class="font-display font-bold text-paper reveal-words"
                    style="font-size: clamp(2.5rem, 5vw, 5rem); line-height: 0.95; letter-spacing: -0.02em;"
                    data-reveal
                    itemprop="name"
                >
                    <span class="block">
                        <span class="word">Your</span>
                        <span class="word">playlist.</span>
                    </span>
                    <span class="block">
                        <span class="word">Your</span>
                        <span class="word">pace.</span>
                    </span>
                    <span class="block">
                        <span class="word">In</span>
                        <span class="word">sync</span>
                        <span class="word">with</span>
                        <span class="word text-cobalt">Spotify.</span>
                    </span>
                </h2>

                <span
                    class="reveal-line text-cobalt mt-6 mb-8 block"
                    style="width: 64px; height: 2px;"
                    data-reveal
                    aria-hidden="true"
                ></span>

                <p
                    class="font-body text-paper-2 text-lg leading-relaxed max-w-[55ch] reveal-fade-rise"
                    data-reveal
                    itemprop="description"
                >
                    Pacebeats reads your tempo and surfaces tracks from your library
                    that match. Your music doesn't just play during your run — it
                    runs with you.
                </p>

                <div class="mt-8 reveal-fade-rise flex flex-wrap items-center gap-4" data-reveal>
                    <span class="chip">
                        Note · Currently available to Spotify developer accounts
                    </span>
                    <!-- Tempo-locked equalizer — visual proof of music-to-stride sync -->
                    <span
                        class="eq-bars"
                        role="img"
                        aria-label="Music tempo visualisation — equalizer bars in motion"
                    >
                        <span class="eq-bar" aria-hidden="true"></span>
                        <span class="eq-bar" aria-hidden="true"></span>
                        <span class="eq-bar" aria-hidden="true"></span>
                        <span class="eq-bar" aria-hidden="true"></span>
                        <span class="eq-bar" aria-hidden="true"></span>
                        <span class="eq-bar" aria-hidden="true"></span>
                        <span class="eq-bar" aria-hidden="true"></span>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- SEO: keep semantic relationship explicit -->
    <div class="sr-only">
        <h3>Spotify integration details</h3>
        <p itemprop="featureList">
            Real-time pace-aware Spotify playback. Tracks are surfaced to match
            your stride and current cadence. Available to Spotify developer
            accounts during beta.
        </p>
    </div>
</section>

<script>
    // Reveal-on-scroll using the global reveal primitives in global.css.
    // Fire once, threshold 0.15, gated on reduced-motion via the global rule.
    if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("is-visible");
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.15, rootMargin: "0px 0px -10% 0px" },
        );

        document
            .querySelectorAll("#maps [data-reveal]")
            .forEach((el) => observer.observe(el));
    } else {
        document
            .querySelectorAll("#maps [data-reveal]")
            .forEach((el) => el.classList.add("is-visible"));
    }
</script>
