---
import { Github, Globe, Linkedin, Facebook } from "@lucide/astro";
import { APK_RELEASE } from "../config/apkRelease";

const year = new Date().getFullYear();

type LinkItem = { label: string; href: string; external?: boolean };
type Column = { title: string; links: LinkItem[] };

const COLUMNS: Column[] = [
    {
        title: "PRODUCT",
        links: [
            { label: "Features", href: "#features" },
            { label: "Wear OS", href: "#wear" },
            { label: "How", href: "#how" },
            { label: "Download APK", href: APK_RELEASE.downloadUrl, external: true },
        ],
    },
    {
        title: "RESOURCES",
        links: [
            {
                label: "Installation Guide",
                href: "/docs/GALAXY_WATCH_INSTALLATION.md",
                external: true,
            },
            {
                label: "GitHub",
                href: "https://github.com/KpG782/pacebeats-release-files",
                external: true,
            },
        ],
    },
    {
        title: "COMPANY",
        links: [
            { label: "Team", href: "#team" },
            { label: "Tech", href: "#techstack" },
        ],
    },
    {
        title: "LEGAL",
        links: [
            { label: "Privacy", href: "/privacy-policy" },
            { label: "Terms", href: "/terms-and-conditions" },
        ],
    },
];
---

<footer
    id="footer"
    class="bg-ink text-paper pt-32 pb-12"
    role="contentinfo"
    aria-label="Site footer"
    itemscope
    itemtype="https://schema.org/WPFooter"
>
    <div class="max-w-7xl mx-auto px-6 md:px-10">
        <!-- Row 1 — wordmark -->
        <div class="mb-20 md:mb-28">
            <h2
                class="font-display font-extrabold leading-none uppercase tracking-[-0.03em] text-outline select-none"
                style="font-size: clamp(4rem, 18vw, 16rem);"
                aria-hidden="true"
            >
                PACEBEATS
            </h2>
            <span class="sr-only">Pacebeats — run to the rhythm.</span>
        </div>

        <!-- Row 2 — 4-column links -->
        <nav
            class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-16"
            role="navigation"
            aria-label="Footer navigation"
        >
            {
                COLUMNS.map((col) => (
                    <div>
                        <h3 class="font-mono text-paper-2 text-xs uppercase tracking-[0.18em] mb-4">
                            {col.title}
                        </h3>
                        <ul class="space-y-3" role="list">
                            {col.links.map((link) => (
                                <li>
                                    <a
                                        href={link.href}
                                        {...(link.external
                                            ? {
                                                  target: "_blank",
                                                  rel: "noopener noreferrer",
                                              }
                                            : {})}
                                        class="link-underline font-body text-paper text-sm hover:text-cobalt-3 transition-colors duration-200"
                                    >
                                        {link.label}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))
            }
        </nav>

        <!-- Row 3 — bottom bar -->
        <div
            class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t border-ink-3"
        >
            <p class="font-mono text-paper-2 text-xs uppercase tracking-[0.12em]">
                © {year} PACEBEATS · MADE IN THE PHILIPPINES
            </p>

            <div
                class="flex items-center gap-5"
                role="list"
                aria-label="Social media"
            >
                <a
                    href="https://github.com/KpG782/pacebeats-release-files"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Pacebeats on GitHub — opens in new tab"
                    class="text-paper-2 hover:text-cobalt-3 transition-colors duration-200"
                >
                    <Github class="w-4 h-4" stroke-width="2" aria-hidden="true" />
                </a>
                <a
                    href="https://www.linkedin.com/company/108121220/"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Pacebeats on LinkedIn — opens in new tab"
                    class="text-paper-2 hover:text-cobalt-3 transition-colors duration-200"
                >
                    <Linkedin class="w-4 h-4" stroke-width="2" aria-hidden="true" />
                </a>
                <a
                    href="https://www.facebook.com/profile.php?id=61579093551639"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Pacebeats on Facebook — opens in new tab"
                    class="text-paper-2 hover:text-cobalt-3 transition-colors duration-200"
                >
                    <Facebook class="w-4 h-4" stroke-width="2" aria-hidden="true" />
                </a>
                <a
                    href="https://www.pacebeats.top"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Pacebeats website — opens in new tab"
                    class="text-paper-2 hover:text-cobalt-3 transition-colors duration-200"
                >
                    <Globe class="w-4 h-4" stroke-width="2" aria-hidden="true" />
                </a>
            </div>
        </div>
    </div>
</footer>

<!-- JSON-LD Structured Data for Organization -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Pacebeats",
    "description": "Running companion app that syncs every stride with the perfect beat.",
    "url": "https://www.pacebeats.top",
    "logo": "https://www.pacebeats.top/favicon.png",
    "sameAs": [
        "https://www.linkedin.com/company/108121220/",
        "https://www.facebook.com/profile.php?id=61579093551639",
        "https://github.com/KpG782/pacebeats-release-files"
    ],
    "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": "pacebeatsspacebeats213@gmail.com",
        "url": "https://www.pacebeats.top"
    },
    "foundingDate": "2024",
    "founder": {
        "@type": "Person",
        "name": "Pacebeats Team"
    }
}
</script>
